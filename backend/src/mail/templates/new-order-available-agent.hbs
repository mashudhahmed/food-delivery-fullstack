<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Order Available - QuickBite Agent</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #1f2937;
      margin: 0;
      padding: 0;
      background-color: #f3f4f6;
    }
    .container {
      max-width: 600px;
      margin: 20px auto;
      background: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }
    .header {
      background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
      color: white;
      padding: 32px;
      text-align: center;
    }
    .logo img {
      width: 50px;
      height: 50px;
      border-radius: 10px;
      margin-bottom: 12px;
    }
    .earnings-badge {
      background: #22c55e;
      color: white;
      padding: 4px 12px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
      display: inline-block;
      margin-top: 12px;
    }
    .content {
      padding: 32px;
    }
    .order-details {
      background: #f9fafb;
      padding: 20px;
      border-radius: 12px;
      margin: 20px 0;
    }
    .detail-row {
      display: flex;
      margin-bottom: 12px;
    }
    .detail-label {
      width: 100px;
      font-weight: 600;
      color: #6b7280;
    }
    .detail-value {
      flex: 1;
      color: #1f2937;
    }
    .button {
      display: inline-block;
      padding: 14px 32px;
      background: #f97316;
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
      margin: 16px 0;
    }
    .footer {
      background: #f9fafb;
      padding: 24px;
      text-align: center;
      font-size: 12px;
      color: #6b7280;
      border-top: 1px solid #e5e7eb;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo">
        <img src="{{logoUrl}}" alt="QuickBite">
      </div>
      <h2>🍕 New Order Available!</h2>
      <div class="earnings-badge">Earn ৳{{earnings}}</div>
    </div>
    
    <div class="content">
      <p>Hello <strong>{{agentName}}</strong>,</p>
      
      <p>A new delivery order is ready for pickup!</p>
      
      <div class="order-details">
        <div class="detail-row">
          <div class="detail-label">Order #:</div>
          <div class="detail-value">{{orderId}}</div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Restaurant:</div>
          <div class="detail-value"><strong>{{restaurantName}}</strong></div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Pickup from:</div>
          <div class="detail-value">{{restaurantAddress}}</div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Deliver to:</div>
          <div class="detail-value">{{deliveryAddress}}</div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Distance:</div>
          <div class="detail-value">~{{distance}} km</div>
        </div>
        <div class="detail-row">
          <div class="detail-label">Delivery Fee:</div>
          <div class="detail-value">৳{{earnings}}</div>
        </div>
      </div>
      
      <center>
        <a href="{{acceptUrl}}" class="button">Accept Delivery →</a>
      </center>
      
      <p style="font-size: 13px; color: #6b7280; text-align: center;">
        Open the QuickBite Agent App to view all available orders.
      </p>
    </div>
    
    <div class="footer">
      <p>QuickBite Agent Portal • Deliver and earn</p>
      <p>© {{year}} QuickBite. All rights reserved.</p>
    </div>
  </div>
</body>
</html>