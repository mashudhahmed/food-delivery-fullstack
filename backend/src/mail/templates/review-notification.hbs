<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Review - QuickBite</title>
  <style>
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
      line-height: 1.6;
      color: #1f2937;
      margin: 0;
      padding: 0;
      background-color: #f3f4f6;
    }
    .container {
      max-width: 600px;
      margin: 20px auto;
      background: #ffffff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
    }
    .header {
      background: linear-gradient(135deg, #f97316 0%, #ea580c 100%);
      color: white;
      padding: 32px;
      text-align: center;
    }
    .logo img {
      width: 50px;
      height: 50px;
      border-radius: 10px;
      margin-bottom: 12px;
    }
    .rating {
      font-size: 32px;
      letter-spacing: 4px;
      margin: 16px 0;
    }
    .review-card {
      background: #f9fafb;
      padding: 24px;
      border-radius: 12px;
      margin: 20px 0;
      border-left: 4px solid #f97316;
    }
    .reviewer-info {
      display: flex;
      align-items: center;
      margin-bottom: 16px;
    }
    .avatar {
      width: 50px;
      height: 50px;
      background: #f97316;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: bold;
      font-size: 20px;
      margin-right: 16px;
    }
    .stats {
      display: flex;
      justify-content: space-around;
      margin: 24px 0;
    }
    .stat-box {
      text-align: center;
    }
    .stat-number {
      font-size: 28px;
      font-weight: 700;
      color: #f97316;
    }
    .button {
      display: inline-block;
      padding: 12px 28px;
      background: #f97316;
      color: white;
      text-decoration: none;
      border-radius: 8px;
      font-weight: 600;
    }
    .footer {
      background: #f9fafb;
      padding: 24px;
      text-align: center;
      font-size: 12px;
      color: #6b7280;
      border-top: 1px solid #e5e7eb;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <div class="logo">
        <img src="{{logoUrl}}" alt="QuickBite">
      </div>
      <h2>⭐ New Review Received!</h2>
      <p>Your restaurant has been reviewed</p>
    </div>
    
    <div class="content">
      <p><strong>Dear {{ownerName}},</strong></p>
      
      <p>A customer just left a review for <strong>{{restaurantName}}</strong>.</p>
      
      <div class="review-card">
        <div class="reviewer-info">
          <div class="avatar">{{getInitials customerName}}</div>
          <div>
            <strong>{{customerName}}</strong><br>
            <small>Reviewed {{formatDate reviewDate}}</small>
          </div>
        </div>
        
        <div class="rating">
          {{#times rating}}⭐{{/times}}
        </div>
        
        <p><strong>Review:</strong></p>
        <p style="font-style: italic;">"{{reviewComment}}"</p>
        
        <p><strong>Order ID:</strong> #{{orderId}}</p>
      </div>
      
      <div class="stats">
        <div class="stat-box">
          <div class="stat-number">{{avgRating}}</div>
          <div>Average Rating</div>
        </div>
        <div class="stat-box">
          <div class="stat-number">{{reviewCount}}</div>
          <div>Total Reviews</div>
        </div>
      </div>
      
      <center>
        <a href="{{dashboardUrl}}" class="button">View All Reviews →</a>
      </center>
      
      <p style="text-align: center; font-size: 13px; color: #6b7280; margin-top: 20px;">
        Respond to reviews to show customers you value their feedback!
      </p>
    </div>
    
    <div class="footer">
      <p>QuickBite Restaurant Dashboard • Manage your reviews</p>
      <p>© {{year}} QuickBite. All rights reserved.</p>
    </div>
  </div>
</body>
</html>